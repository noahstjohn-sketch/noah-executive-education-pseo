---
// src/pages/[topic].astro
// SSR mode: Astro.params at runtime. Never getStaticPaths().
import Base from '../layouts/Base.astro';
import PageTemplate from '../components/PageTemplate.astro';
import { topics } from '../data/topics.js';
import { buildPageData } from '../lib/page-data.js';

const { topic: topicSlug } = Astro.params;
const topic = topics.find(t => t.slug === topicSlug);
if (!topic) return Astro.redirect('/404');

const { faq, faqSchema, aboutText } = buildPageData(topic, null);

const title = `${topic.label} | Dr. Noah St. John | Neural Performance Architect`;
const description = topic.desc;
const canonical = `https://executive-education.noahstjohn.com/${topic.slug}`;
---
<Base title={title} description={description} canonical={canonical} faqSchema={faqSchema}>
  <PageTemplate topic={topic} niche={null} faq={faq} aboutText={aboutText} />
</Base>
